{
  "name": "todo-ext",
  "displayName": "TODO Finder",
  "description": "Encuentra, organiza y gestiona TODOs/FIXMEs en tu proyecto: filtros, estados locales, integración con GitHub/GitLab, CodeLens y más.",
  "version": "0.1.0",
  "publisher": "TU_PUBLISHER_ID_AQUI",
  "license": "MIT",
  "keywords": [
    "todo",
    "fixme",
    "tasks",
    "comments",
    "github",
    "gitlab",
    "issues",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TU_USUARIO/todo-ext"
  },
  "bugs": {
    "url": "https://github.com/TU_USUARIO/todo-ext/issues"
  },
  "homepage": "https://github.com/TU_USUARIO/todo-ext#readme",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "todoFinder.refresh",
        "title": "Refrescar TODOs",
        "icon": "$(refresh)"
      },
      {
        "command": "todoFinder.filter",
        "title": "Filtrar TODOs",
        "icon": "$(filter)"
      },
      {
        "command": "todoFinder.clearFilter",
        "title": "Limpiar filtro de TODOs",
        "icon": "$(filter-filled)"
      },
      {
        "command": "todoFinder.filterByTag",
        "title": "Filtrar por esta etiqueta"
      },
      {
        "command": "todoFinder.filterByFolder",
        "title": "Filtrar por esta carpeta"
      },
      {
        "command": "todoFinder.markIssue",
        "title": "Marcar como issue"
      },
      {
        "command": "todoFinder.markDone",
        "title": "Marcar como resuelto"
      },
      {
        "command": "todoFinder.markWontfix",
        "title": "Marcar como wontfix"
      },
      {
        "command": "todoFinder.markInProgress",
        "title": "Marcar como en progreso"
      },
      {
        "command": "todoFinder.clearStatus",
        "title": "Quitar estado"
      },
      {
        "command": "todoFinder.createIssue",
        "title": "Crear issue en GitHub/GitLab"
      },
      {
        "command": "todoFinder.openLinkedIssue",
        "title": "Abrir issue vinculado"
      },
      {
        "command": "todoFinder.exportMarkdown",
        "title": "Exportar a Markdown",
        "icon": "$(markdown)"
      },
      {
        "command": "todoFinder.goToNext",
        "title": "TODO Finder: Ir al siguiente fixture"
      },
      {
        "command": "todoFinder.goToPrevious",
        "title": "TODO Finder: Ir al fixture anterior"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "todoFinder.refresh",
          "when": "view == todoTree",
          "group": "navigation"
        },
        {
          "command": "todoFinder.filter",
          "when": "view == todoTree && !todoFinder.filterActive",
          "group": "navigation"
        },
        {
          "command": "todoFinder.clearFilter",
          "when": "view == todoTree && todoFinder.filterActive",
          "group": "navigation"
        },
        {
          "command": "todoFinder.exportMarkdown",
          "when": "view == todoTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "todoFinder.filterByTag",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "1_filter"
        },
        {
          "command": "todoFinder.filterByFolder",
          "when": "view == todoTree && viewItem == todoFile",
          "group": "1_filter"
        },
        {
          "command": "todoFinder.markIssue",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "2_status"
        },
        {
          "command": "todoFinder.markDone",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "2_status"
        },
        {
          "command": "todoFinder.markWontfix",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "2_status"
        },
        {
          "command": "todoFinder.markInProgress",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "2_status"
        },
        {
          "command": "todoFinder.clearStatus",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "2_status"
        },
        {
          "command": "todoFinder.createIssue",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "3_issue"
        },
        {
          "command": "todoFinder.openLinkedIssue",
          "when": "view == todoTree && viewItem == todoFixture",
          "group": "3_issue"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todo-explorer",
          "title": "TODO Finder",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "todo-explorer": [
        {
          "id": "todoTree",
          "name": "Tareas Pendientes"
        }
      ]
    },
    "configuration": {
      "title": "TODO Finder",
      "properties": {
        "todoFinder.includeDefaultTags": {
          "type": "boolean",
          "default": true,
          "description": "Incluye las etiquetas por defecto (TODO, FIXME, DEBUG) además de las personalizadas."
        },
        "todoFinder.customTags": {
          "type": "array",
          "default": [],
          "description": "Etiquetas personalizadas a detectar, ej. REVIEW, IDEA, BUG.",
          "items": {
            "type": "object",
            "required": ["keyword"],
            "properties": {
              "keyword": {
                "type": "string",
                "description": "Palabra clave a detectar, ej. REVIEW"
              },
              "color": {
                "type": "string",
                "description": "Color CSS para resaltar la etiqueta, ej. #FFA500"
              },
              "icon": {
                "type": "string",
                "description": "Emoji o carácter opcional a mostrar antes de la etiqueta en el editor, ej. ⚠️"
              }
            }
          }
        },
        "todoFinder.include": {
          "type": "string",
          "default": "**/*.{ts,js,py,md,txt,php}",
          "description": "Patrón glob de archivos a escanear en busca de TODOs."
        },
        "todoFinder.exclude": {
          "type": "string",
          "default": "**/{node_modules,vendor}/**",
          "description": "Patrón glob de archivos/carpetas a excluir del escaneo."
        },
        "todoFinder.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Muestra un CodeLens de acciones rápidas sobre cada TODO/FIXME detectado."
        },
        "todoFinder.decorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Resalta los TODOs/FIXMEs directamente en el editor."
        },
        "todoFinder.gitBlame.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Muestra autor y fecha (vía git blame) en el tooltip de cada fixture."
        },
        "todoFinder.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Muestra la cantidad de fixtures pendientes en la barra de estado."
        },
        "todoFinder.treeView.sortOrder": {
          "type": "string",
          "enum": ["path", "priority"],
          "enumDescriptions": [
            "Ordena los fixtures de cada archivo por línea (orden de aparición).",
            "Ordena los fixtures de cada archivo por prioridad (alta → media → baja → sin prioridad)."
          ],
          "default": "path",
          "description": "Orden de los fixtures dentro de cada archivo en el árbol."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "install:local": "bash scripts/install-local.sh"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "todo-ext": "link:"
  }
}